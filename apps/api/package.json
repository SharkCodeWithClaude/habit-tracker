    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@habit-tracker/shared": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/bcryptjs": "^3.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "typescript-eslint": "^8",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
